# Database
DATABASE_URL="postgres://postgres:PASSWORD@tropical-vitamin.com:5432/tropical_vitamin"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Email (Gmail SMTP)
