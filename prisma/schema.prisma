// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TOURS
// ============================================

model Tour {
  id          Int      @id @default(autoincrement())
  adminTitle  String   // nombre interno para el panel admin
  price       Decimal  @db.Decimal(10, 2)
  location    String
  duration    Int      @default(60) // duración en minutos
  img         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations TourTranslation[]

  @@index([categoryId])
  @@index([isActive])
}

model TourTranslation {
  id          Int    @id @default(autoincrement())
  title       String
  description String

  tourId Int
  tour   Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  languageId Int      @default(1)  // temporal, ajustar desde admin
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([tourId, languageId])
  @@index([languageId])
}

// ============================================
// CATEGORIES
// ============================================

model Category {
  id          Int    @id @default(autoincrement())
  adminName   String @unique // identificador interno para el panel admin
  description String // descripción interna para el admin

  // Relaciones
  translations CategoryTranslation[]
  tours        Tour[]

  @@index([adminName])
}

model CategoryTranslation {
  id          Int    @id @default(autoincrement())
  name        String // nombre visible para usuarios
  description String // descripción visible para usuarios

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  languageId Int
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageId])
  @@index([languageId])
}

// ============================================
// USERS
// ============================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ============================================
// LANGUAGES
// ============================================

model Language {
  id          Int    @id @default(autoincrement())
  code        String @unique // 'es', 'en', 'fr', etc.
  name        String // 'Español', 'English', 'Français', etc.
  isActive    Boolean @default(true)

  tourTranslations     TourTranslation[]
  categoryTranslations CategoryTranslation[]

  @@index([code])
}